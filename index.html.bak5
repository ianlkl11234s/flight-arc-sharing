<!doctype html>
<html lang="zh-Hant">
<head>
<meta charset="utf-8" />
<title>長榮開發分享 — 成果介紹 Showcase</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<script src="deck-stage.js"></script>
<link rel="stylesheet" href="styles-mindset.css" />
<link rel="stylesheet" href="styles-system.css" />
<link rel="stylesheet" href="styles-build.css" />
<link rel="stylesheet" href="styles-horizon.css" />
<template id="__bundler_thumbnail">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
    <rect width="100" height="100" fill="#0A0E1A"/>
    <g fill="none" stroke="#5BE0E8" stroke-width="2" stroke-linecap="round">
      <path d="M20 78 Q42 30 80 24" opacity="0.9"/>
      <path d="M24 82 Q44 44 78 40" opacity="0.5"/>
      <path d="M30 84 Q48 58 76 56" opacity="0.3"/>
    </g>
    <circle cx="80" cy="24" r="4" fill="#5BE0E8"/>
    <circle cx="80" cy="24" r="9" fill="none" stroke="#5BE0E8" stroke-width="1.5" opacity="0.5"/>
  </svg>
</template>
<style>
  :root{
    --ink:#0A0E1A; --ink-2:#0F1525; --ink-3:#141B30;
    --line:rgba(255,255,255,0.08); --line-strong:rgba(255,255,255,0.16);
    --fg:#EAEEF7; --fg-dim:#B8C0D2; --fg-mute:#7B85A0;
    --cyan:#5BE0E8; --amber:#F5A524; --magenta:#D946EF; --green:#22D38C; --rose:#FF6B8A;
    /* type scale */
    --t-mega:150px; --t-title:96px; --t-title-sm:72px; --t-sub:42px;
    --t-body:34px; --t-small:30px; --t-mono:26px; --t-micro:22px;
    --t-num:88px;
    --pad-x:96px; --pad-top:120px; --pad-bottom:88px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;background:#000;font-family:"Noto Sans TC",system-ui,sans-serif;color:var(--fg);overflow:hidden;}
  deck-stage{background:#000;}
  section.slide{background:var(--ink);color:var(--fg);font-family:"Noto Sans TC",system-ui,sans-serif;font-weight:400;overflow:hidden;position:relative;}
  .mono{font-family:"JetBrains Mono",ui-monospace,monospace;}
  .frame{width:100%;height:100%;padding:var(--pad-top) var(--pad-x) var(--pad-bottom);display:flex;flex-direction:column;}

  /* ---------- chrome ---------- */
  .chrome-top{position:absolute;top:52px;left:var(--pad-x);right:var(--pad-x);display:flex;justify-content:space-between;align-items:center;
    font-family:"JetBrains Mono",monospace;font-size:24px;letter-spacing:0.14em;color:var(--fg-mute);z-index:6;
    padding-bottom:16px;border-bottom:1px solid var(--line);text-transform:uppercase;}
  .chrome-top .mark{display:flex;align-items:center;gap:14px;}
  .chrome-top .mark .dot{width:10px;height:10px;border-radius:50%;background:var(--cyan);box-shadow:0 0 14px var(--cyan);flex:0 0 10px;}
  .chrome-top .pg{font-variant-numeric:tabular-nums;}
  /* on full-bleed slides: a single tidy line pinned top-right, clear of the
     product screenshots' own baked-in title overlay (which sits top-left). */
  .full .chrome-top{left:auto;right:var(--pad-x);top:46px;width:auto;flex-direction:row;align-items:center;gap:24px;
    border-bottom:none;padding-bottom:0;white-space:nowrap;font-size:24px;text-shadow:0 2px 16px rgba(0,0,0,0.95);}
  .full .chrome-top .mark{white-space:nowrap;}
  .full .chrome-top .pg{color:var(--fg-dim);}

  /* ---------- shared atoms ---------- */
  .stamp{display:inline-flex;align-items:center;gap:12px;font-family:"JetBrains Mono",monospace;font-size:24px;letter-spacing:0.14em;
    text-transform:uppercase;color:var(--fg);background:rgba(10,14,26,0.78);border:1px solid var(--line-strong);
    border-radius:6px;padding:12px 20px;backdrop-filter:blur(8px);}
  .stamp.cy{border-color:rgba(91,224,232,0.55);color:var(--cyan);background:rgba(91,224,232,0.08);}
  .stamp .k{color:var(--fg-mute);}
  .cornermono{position:absolute;right:var(--pad-x);bottom:64px;z-index:5;font-family:"JetBrains Mono",monospace;font-size:24px;
    letter-spacing:0.1em;color:var(--fg-dim);text-shadow:0 2px 12px rgba(0,0,0,0.9);text-transform:uppercase;}
  .demo-pill{display:inline-flex;align-items:center;gap:14px;font-family:"JetBrains Mono",monospace;font-size:24px;letter-spacing:0.2em;
    text-transform:uppercase;color:var(--cyan);border:1px solid rgba(91,224,232,0.6);background:rgba(91,224,232,0.10);
    border-radius:40px;padding:14px 28px;backdrop-filter:blur(8px);}
  .demo-pill .tri{width:0;height:0;border-left:18px solid var(--cyan);border-top:11px solid transparent;border-bottom:11px solid transparent;}

  /* ---------- full-bleed case ---------- */
  .full .frame{padding:0;}
  .full .bg{position:absolute;inset:0;background-size:cover;background-position:center;}
  .scrim{position:absolute;inset:0;z-index:1;}
  .scrim.bottom{background:linear-gradient(180deg,rgba(10,14,26,0.55) 0%,rgba(10,14,26,0) 22%,rgba(10,14,26,0) 52%,rgba(10,14,26,0.92) 100%);}
  .scrim.left{background:linear-gradient(90deg,rgba(10,14,26,0.92) 0%,rgba(10,14,26,0.55) 40%,rgba(10,14,26,0) 78%);}
  .scrim.tl{background:linear-gradient(135deg,rgba(10,14,26,0.9) 0%,rgba(10,14,26,0.25) 45%,rgba(10,14,26,0) 70%);}
  .full-body{position:absolute;left:var(--pad-x);right:var(--pad-x);bottom:var(--pad-bottom);z-index:3;}
  .case-label{font-family:"JetBrains Mono",monospace;font-size:26px;color:var(--cyan);letter-spacing:0.18em;margin-bottom:18px;}
  .full h2{font-size:var(--t-title);font-weight:700;line-height:1.02;letter-spacing:-0.02em;margin:0 0 18px;text-wrap:balance;}
  .full .sub{font-size:var(--t-sub);color:var(--fg-dim);font-weight:300;line-height:1.4;margin:0;max-width:1500px;}
  .full .sub strong{color:var(--fg);font-weight:500;}

  .bottom-row{display:flex;align-items:flex-end;justify-content:space-between;gap:60px;}
  .meta-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px;font-family:"JetBrains Mono",monospace;
    font-size:24px;color:var(--fg-mute);letter-spacing:0.06em;text-align:right;line-height:1.4;flex:0 0 auto;}
  .meta-list li strong{color:var(--fg);font-weight:500;}

  /* big inline numbers row */
  .numrow{display:flex;gap:72px;align-items:flex-end;margin-top:8px;}
  .numrow .stat .n{font-family:"JetBrains Mono",monospace;font-size:var(--t-num);font-weight:700;line-height:1;color:#fff;white-space:nowrap;text-shadow:0 2px 18px rgba(0,0,0,0.6);}
  .numrow .stat .n .u{font-size:34px;color:var(--fg-dim);margin-left:8px;font-weight:400;}
  .numrow .stat .l{font-family:"JetBrains Mono",monospace;font-size:24px;color:var(--fg-mute);letter-spacing:0.14em;text-transform:uppercase;margin-top:12px;}

  /* leader callout */
  .callout{position:absolute;z-index:4;display:flex;flex-direction:column;gap:8px;}
  .callout .lbl{font-family:"JetBrains Mono",monospace;font-size:24px;letter-spacing:0.08em;color:var(--cyan);background:rgba(10,14,26,0.7);
    border:1px solid rgba(91,224,232,0.45);border-radius:6px;padding:10px 16px;backdrop-filter:blur(6px);white-space:nowrap;text-shadow:0 1px 6px rgba(0,0,0,0.8);}
  .callout .lbl.amber{color:var(--amber);border-color:rgba(245,165,36,0.5);}
  .callout .ln{height:2px;background:linear-gradient(90deg,var(--cyan),transparent);}
  .callout .ln.amber{background:linear-gradient(90deg,var(--amber),transparent);}

  /* legend */
  .legend{position:absolute;z-index:4;background:rgba(10,14,26,0.82);border:1px solid var(--line-strong);border-radius:8px;
    padding:18px 22px;backdrop-filter:blur(8px);display:flex;flex-direction:column;gap:12px;}
  .legend .it{display:flex;align-items:center;gap:14px;font-size:26px;color:var(--fg-dim);font-weight:300;}
  .legend .it .sw{width:26px;height:6px;border-radius:3px;flex:0 0 26px;}

  /* ---------- section cover ---------- */
  .s-cover{background:radial-gradient(ellipse at 25% 55%,rgba(91,224,232,0.10) 0,transparent 55%),radial-gradient(ellipse at 80% 35%,rgba(245,165,36,0.06) 0,transparent 55%),var(--ink);}
  .s-cover .frame{padding:130px 130px 110px;justify-content:space-between;}
  .s-cover .num-mega{position:absolute;right:50px;bottom:0px;font-family:"JetBrains Mono",monospace;font-size:340px;font-weight:700;
    line-height:0.85;color:rgba(255,255,255,0.045);letter-spacing:-0.05em;pointer-events:none;}
  .s-cover .eyebrow{font-family:"JetBrains Mono",monospace;font-size:28px;letter-spacing:0.2em;color:var(--fg-mute);text-transform:uppercase;
    display:flex;align-items:center;gap:18px;}
  .s-cover .eyebrow::before{content:"";width:34px;height:2px;background:var(--cyan);}
  .s-cover h2{font-size:128px;line-height:1.02;font-weight:700;margin:18px 0 0;letter-spacing:-0.02em;}
  .s-cover .lead{font-size:40px;color:var(--fg-dim);max-width:1300px;line-height:1.5;font-weight:300;margin-top:30px;}
  .s-cover .lead strong{color:var(--fg);font-weight:500;}
  .s-cover .toc{display:flex;gap:54px;font-family:"JetBrains Mono",monospace;font-size:25px;color:var(--fg-mute);letter-spacing:0.1em;}
  .s-cover .toc span.now{color:var(--cyan);}
  .s-cover .toc span.now::before{content:"● ";}

  /* ---------- concept: video bridge (P12) ---------- */
  .s-bridge .frame{padding:var(--pad-top) 110px var(--pad-bottom);}
  .bridge-head h2{font-size:var(--t-title);font-weight:700;margin:0 0 14px;letter-spacing:-0.02em;}
  .bridge-head .sub{font-size:var(--t-sub);color:var(--fg-dim);font-weight:300;margin:0;}
  .bridge-stage{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;margin-top:8px;}
  .bridge-pair{display:flex;gap:56px;width:100%;justify-content:center;}
  .bridge-card{flex:1;max-width:760px;border-radius:14px;overflow:hidden;border:1px solid var(--line-strong);position:relative;
    box-shadow:0 30px 70px rgba(0,0,0,0.5);background:#000;aspect-ratio:16/9;}
  .bridge-card .ci{position:absolute;inset:0;background-size:cover;background-position:center;}
  .bridge-card .vscrim{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0.15),rgba(0,0,0,0.78));}
  .bridge-card .play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:96px;height:96px;border-radius:50%;
    border:2px solid rgba(255,255,255,0.85);display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.35);backdrop-filter:blur(4px);}
  .bridge-card .play .tri{width:0;height:0;border-left:30px solid #fff;border-top:19px solid transparent;border-bottom:19px solid transparent;margin-left:7px;}
  .bridge-card .cap{position:absolute;left:28px;bottom:24px;z-index:2;}
  .bridge-card .cap .t{font-size:36px;font-weight:700;color:#fff;}
  .bridge-card .cap .m{font-family:"JetBrains Mono",monospace;font-size:24px;color:var(--cyan);letter-spacing:0.08em;margin-top:6px;}
  .bridge-converge{display:flex;flex-direction:column;align-items:center;gap:16px;margin-top:30px;}
  .bridge-converge .v{width:2px;height:46px;background:linear-gradient(180deg,transparent,var(--cyan));}
  .bridge-converge .dest{display:flex;align-items:center;gap:20px;padding:18px 34px;border:1px solid rgba(91,224,232,0.5);
    border-radius:50px;background:rgba(91,224,232,0.08);}
  .bridge-converge .dest .plane{color:var(--cyan);}
  .bridge-converge .dest .lab{font-size:40px;font-weight:700;color:#fff;}
  .bridge-converge .dest .lab .en{font-family:"JetBrains Mono",monospace;font-size:28px;color:var(--cyan);letter-spacing:0.14em;margin-left:14px;}

  /* ---------- gallery (P14a) ---------- */
  .s-gallery .frame{padding:0;}
  .gal{position:absolute;inset:0;display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;gap:5px;background:var(--ink);}
  .gal .cell{position:relative;overflow:hidden;}
  .gal .cell .ci{position:absolute;inset:0;background-size:cover;background-position:center;}
  .gal .cell .icao{position:absolute;left:30px;bottom:26px;z-index:2;font-family:"JetBrains Mono",monospace;}
  .gal .cell .icao .code{font-size:40px;font-weight:700;color:#fff;letter-spacing:0.06em;text-shadow:0 2px 12px rgba(0,0,0,0.9);}
  .gal .cell .icao .nm{font-size:24px;color:var(--fg-dim);letter-spacing:0.1em;margin-top:4px;text-shadow:0 2px 10px rgba(0,0,0,0.9);}

  /* ---------- VS dual (P22) ---------- */
  .s-vs .frame{padding:var(--pad-top) 110px var(--pad-bottom);}
  .vs-head h2{font-size:var(--t-title-sm);font-weight:700;margin:0 0 12px;letter-spacing:-0.015em;}
  .vs-head .sub{font-size:var(--t-sub);color:var(--fg-dim);font-weight:300;margin:0;}
  .vs-stage{flex:1;display:flex;align-items:center;justify-content:center;gap:44px;margin-top:18px;position:relative;min-height:0;}
  .vs-card{flex:0 1 600px;display:flex;flex-direction:column;gap:18px;min-height:0;}
  .vs-card .shot{width:100%;aspect-ratio:1/1;border-radius:14px;overflow:hidden;border:1px solid var(--line-strong);
    box-shadow:0 24px 60px rgba(0,0,0,0.5);background:#000;}
  .vs-card .shot .ci{width:100%;height:100%;background-size:cover;background-position:center;}
  .vs-card .cap{display:flex;align-items:baseline;justify-content:space-between;gap:20px;}
  .vs-card .cap .nm{font-family:"JetBrains Mono",monospace;font-size:34px;font-weight:700;color:#fff;letter-spacing:0.06em;}
  .vs-card .cap .nm.cy{color:var(--cyan);}
  .vs-card .cap .tag{font-size:26px;color:var(--fg-dim);font-weight:300;}
  .vs-mid{flex:0 0 auto;font-family:"JetBrains Mono",monospace;font-size:40px;font-weight:700;color:var(--fg-mute);letter-spacing:0.1em;}

  /* ---------- dashboard floating (P24/25/26) ---------- */
  .s-dash .frame{padding:var(--pad-top) 90px var(--pad-bottom);}
  .dash-head{display:flex;justify-content:space-between;align-items:flex-end;gap:50px;}
  .dash-head .left h2{font-size:var(--t-title-sm);font-weight:700;margin:0;line-height:1.04;letter-spacing:-0.015em;}
  .dash-head .left .eb{font-family:"JetBrains Mono",monospace;font-size:24px;color:var(--cyan);letter-spacing:0.18em;margin-bottom:14px;text-transform:uppercase;}
  .dash-head .left .sub{font-size:var(--t-small);color:var(--fg-dim);font-weight:300;margin-top:14px;line-height:1.4;max-width:1100px;}
  .dash-head .right{font-family:"JetBrains Mono",monospace;font-size:24px;color:var(--fg-mute);letter-spacing:0.1em;text-align:right;line-height:1.6;white-space:nowrap;}
  .dash-body{flex:1;display:flex;gap:54px;margin-top:30px;min-height:0;}
  .shot-panel{border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.14);box-shadow:0 0 0 1px rgba(255,255,255,0.06),0 30px 80px rgba(0,0,0,0.6),0 0 60px rgba(91,224,232,0.06);background:#fff;display:flex;align-items:center;justify-content:center;min-height:0;}
  .shot-panel img{display:block;max-width:100%;max-height:100%;width:auto;height:auto;object-fit:contain;background:#fff;}

  /* metric compare strip */
  .metrics{display:flex;flex-direction:column;gap:22px;justify-content:center;}
  .metric{border:1px solid var(--line);border-radius:12px;padding:24px 28px;background:rgba(255,255,255,0.025);}
  .metric .ml{font-size:26px;color:var(--fg-dim);font-weight:300;margin-bottom:12px;}
  .metric .mvrow{display:flex;align-items:baseline;gap:18px;}
  .metric .big{font-family:"JetBrains Mono",monospace;font-size:60px;font-weight:700;line-height:1;color:var(--cyan);}
  .metric .delta{font-family:"JetBrains Mono",monospace;font-size:28px;color:var(--rose);font-weight:500;}
  .metric .vs{font-size:24px;color:var(--fg-mute);}
  .metric .dry{font-family:"JetBrains Mono",monospace;font-size:34px;color:var(--fg-mute);font-weight:500;}
  /* ---- P24–26 全頁白底 · 產品主視覺 ---- */
  section.slide.s-light{background:#EEF2F8;color:#0A0E1A;
    --fg:#0A0E1A;--fg-dim:#3c4456;--fg-mute:#6b7488;
    --line:rgba(10,14,26,0.12);--line-strong:rgba(10,14,26,0.18);
    --cyan:#0E9C8E;--rose:#d12d57;--amber:#c9760f;}
  .s-light .chrome-top{text-shadow:none;}
  .s-light .shot-panel{border-color:rgba(10,14,26,0.14);box-shadow:0 1px 0 rgba(10,14,26,0.04),0 24px 64px rgba(10,14,26,0.18);}
  .s-light .metric{background:#ffffff;border-color:rgba(10,14,26,0.10);box-shadow:0 8px 24px rgba(10,14,26,0.06);}
  /* ---- LIVE DEMO 切換頁 ---- */
  section.slide.s-livedemo{background:#05070D;}
  .s-livedemo .ld-bg{position:absolute;inset:0;display:grid;grid-template-columns:repeat(3,1fr);}
  .s-livedemo .ld-bg>div{background-size:cover;background-position:center;opacity:0.2;}
  .s-livedemo .ld-scrim{position:absolute;inset:0;background:radial-gradient(120% 90% at 50% 50%,rgba(5,7,13,0.5),rgba(5,7,13,0.93));}
  .s-livedemo .ld-center{position:absolute;inset:0;z-index:4;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:0 var(--pad-x);gap:34px;}
  .s-livedemo .ld-pill{display:inline-flex;align-items:center;gap:18px;font-family:"JetBrains Mono",monospace;font-size:30px;letter-spacing:0.2em;color:var(--cyan);border:1.5px solid rgba(91,224,232,0.55);border-radius:999px;padding:16px 42px;background:rgba(91,224,232,0.08);text-transform:uppercase;}
  .s-livedemo .ld-pill .tri{width:0;height:0;border-left:22px solid var(--cyan);border-top:13px solid transparent;border-bottom:13px solid transparent;}
  .s-livedemo .ld-title{font-size:140px;font-weight:900;line-height:1;margin:0;color:#fff;letter-spacing:-0.02em;text-shadow:0 6px 44px rgba(0,0,0,0.65);}
  .s-livedemo .ld-sub{font-size:42px;color:var(--fg-dim);font-weight:300;max-width:1280px;margin:0;line-height:1.45;}
  /* ---- Q&A 聯絡 QR ---- */
  .qa-contact{display:flex;justify-content:center;gap:64px;margin-top:56px;}
  .qa-contact .qc{display:flex;flex-direction:column;align-items:center;gap:18px;}
  .qa-contact .qc img{width:240px;height:240px;border-radius:16px;background:#fff;padding:14px;box-shadow:0 20px 50px rgba(0,0,0,0.5);}
  .qa-contact .qc .k{font-family:"JetBrains Mono",monospace;font-size:25px;letter-spacing:0.18em;color:var(--fg-mute);}
  .qa-contact .qc .v{font-size:32px;color:var(--fg);font-weight:500;}

  /* ---------- P21 capability hub ---------- */
  .s-hub .frame{padding:var(--pad-top) 110px var(--pad-bottom);}
  .hub-head h2{font-size:var(--t-title-sm);font-weight:700;margin:0 0 12px;letter-spacing:-0.015em;}
  .hub-head .sub{font-size:var(--t-sub);color:var(--fg-dim);font-weight:300;margin:0;}
  .hub-stage{flex:1;display:grid;grid-template-columns:1fr auto 1fr;grid-template-rows:1fr 1fr;gap:36px 90px;align-items:center;
    justify-items:center;margin-top:14px;position:relative;}
  .hub-core{grid-column:2;grid-row:1/3;width:300px;height:330px;display:flex;flex-direction:column;align-items:center;justify-content:center;
    border:2px solid rgba(91,224,232,0.5);border-radius:24px;background:radial-gradient(ellipse at 50% 30%,rgba(91,224,232,0.16),rgba(91,224,232,0.02) 70%);
    box-shadow:0 0 70px rgba(91,224,232,0.14) inset,0 0 50px rgba(91,224,232,0.1);position:relative;z-index:2;gap:10px;}
  .hub-core .icn{color:var(--cyan);}
  .hub-core .n{font-family:"JetBrains Mono",monospace;font-size:48px;font-weight:700;color:#fff;line-height:1;}
  .hub-core .t{font-size:30px;color:var(--fg-dim);font-weight:300;}
  .hub-node{width:100%;max-width:430px;border:1px solid var(--line);border-radius:14px;padding:26px 30px;background:rgba(255,255,255,0.025);z-index:2;}
  .hub-node .hn{display:flex;align-items:center;gap:16px;margin-bottom:10px;}
  .hub-node .hn .icn{color:var(--cyan);flex:0 0 auto;}
  .hub-node .hn .nm{font-size:38px;font-weight:700;color:#fff;}
  .hub-node .desc{font-size:27px;color:var(--fg-dim);font-weight:300;line-height:1.4;}
  .hub-node .ref{font-family:"JetBrains Mono",monospace;font-size:24px;color:var(--cyan);letter-spacing:0.1em;margin-top:10px;}
  .hub-foot{text-align:center;font-size:var(--t-sub);color:var(--fg);font-weight:300;margin-top:6px;}
  .hub-foot strong{color:var(--cyan);font-weight:600;}

  /* ---------- P27 cycle ---------- */
  .s-cycle .frame{padding:var(--pad-top) 90px var(--pad-bottom);}
  .cycle-head h2{font-size:var(--t-title-sm);font-weight:700;margin:0 0 12px;letter-spacing:-0.015em;}
  .cycle-head .sub{font-size:var(--t-sub);color:var(--fg-dim);font-weight:300;margin:0;}
  .cycle-body{flex:1;display:grid;grid-template-columns:560px 1fr;gap:70px;margin-top:24px;align-items:center;}
  .ring{position:relative;width:520px;height:520px;margin:0 auto;}
  .ring .circ{position:absolute;inset:40px;border-radius:50%;border:2px dashed rgba(91,224,232,0.3);}
  .ring .ctr{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:230px;height:230px;border-radius:50%;
    background:radial-gradient(circle,rgba(91,224,232,0.12),rgba(91,224,232,0.02) 70%);border:1px solid rgba(91,224,232,0.35);
    display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:8px;}
  .ring .ctr .t{font-size:32px;font-weight:700;color:#fff;line-height:1.2;}
  .ring .ctr .m{font-family:"JetBrains Mono",monospace;font-size:24px;color:var(--cyan);letter-spacing:0.12em;}
  .ring .node{position:absolute;transform:translate(-50%,-50%);display:flex;flex-direction:column;align-items:center;gap:6px;width:160px;text-align:center;}
  .ring .node .dot{width:22px;height:22px;border-radius:50%;background:var(--cyan);box-shadow:0 0 18px var(--cyan);}
  .ring .node .nm{font-size:30px;font-weight:700;color:var(--fg);}
  .ring .node .en{font-family:"JetBrains Mono",monospace;font-size:24px;color:var(--fg-mute);letter-spacing:0.1em;}
  .cycle-right{display:flex;flex-direction:column;gap:26px;}
  .cycle-info{max-width:860px;border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.14);box-shadow:0 24px 60px rgba(0,0,0,0.55),0 0 50px rgba(91,224,232,0.05);}
  .cycle-info .head{display:flex;justify-content:space-between;align-items:center;padding:14px 22px;background:rgba(255,255,255,0.04);border-bottom:1px solid var(--line);
    font-family:"JetBrains Mono",monospace;font-size:24px;color:var(--cyan);letter-spacing:0.08em;}
  .cycle-info img{display:block;width:100%;}
  .cycle-note{font-size:30px;color:var(--fg-dim);font-weight:300;line-height:1.5;}
  .cycle-note strong{color:var(--fg);font-weight:600;}

  /* entrance — content is ALWAYS visible (no opacity hiding, so print/PDF/export
     always render). A gentle transform-only rise plays when the slide becomes active. */
  @media (prefers-reduced-motion:no-preference){
    section.slide[data-deck-active] .anim{animation:rise 0.5s cubic-bezier(0.2,0.7,0.2,1) both;}
    section.slide[data-deck-active] .anim.d1{animation-delay:0.06s;}
    section.slide[data-deck-active] .anim.d2{animation-delay:0.12s;}
    section.slide[data-deck-active] .anim.d3{animation-delay:0.18s;}
    @keyframes rise{from{transform:translateY(18px);}to{transform:none;}}
  }
</style>
<style>
/* ===== ported from 數據人之夜 (scoped .pj) ===== */
/* ===== Shared helpers (eyebrow / title / subtitle) ===== */
  .pj .eyebrow { font-family: "JetBrains Mono", monospace; font-size: 28px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--fg-mute); margin-bottom: 28px; display: flex; align-items: center; gap: 18px; }
  .pj .eyebrow::before { content: ""; width: 32px; height: 2px; background: var(--fg-mute); display: inline-block; }
  .pj h1.title { font-size: 104px; line-height: 1.05; letter-spacing: -0.02em; font-weight: 700; margin: 0 0 28px; text-wrap: balance; }
  .pj h2.title { font-size: 84px; line-height: 1.08; letter-spacing: -0.015em; font-weight: 700; margin: 0 0 24px; text-wrap: balance; }
  .pj .subtitle { font-size: 42px; color: var(--fg-dim); font-weight: 300; line-height: 1.4; margin: 0; }

/* ---- slide 19: Knowledge Base (s-kb) ---- */
  .s-kb .frame { padding: 110px 80px 95px; }
  .kb-stages { flex: 1; display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 40px; position: relative; align-items: stretch; min-height: 0; }
  .kb-stages::before { content: ""; position: absolute; left: 8%; right: 8%; top: 14px; height: 2px; background: linear-gradient(90deg, rgba(123,133,160,0.3), rgba(245,165,36,0.5), rgba(91,224,232,0.85)); z-index: 0; }
  .kb-stage:not(.now)::after { content: "→"; position: absolute; right: -22px; top: 50%; transform: translateY(-50%); font-family: "JetBrains Mono", monospace; font-size: 28px; color: var(--fg-mute); z-index: 2; }
  .kb-stage { background: rgba(255,255,255,0.025); border: 1px solid var(--line); border-radius: 12px; padding: 26px 24px; display: flex; flex-direction: column; gap: 14px; position: relative; z-index: 1; min-height: 0; overflow: hidden; }
  .kb-stage.now { background: linear-gradient(180deg, rgba(91,224,232,0.10), rgba(91,224,232,0.02)); border-color: rgba(91,224,232,0.45); }
  .kb-stage .head { display: flex; align-items: center; gap: 18px; }
  .kb-stage .badge { width: 52px; height: 52px; border-radius: 50%; border: 2px solid var(--fg-mute); display: flex; align-items: center; justify-content: center; font-family: "JetBrains Mono", monospace; font-weight: 700; color: var(--fg-mute); font-size: 24px; }
  .kb-stage.now .badge { border-color: var(--cyan); color: var(--cyan); }
  .kb-stage .stage-name { font-family: "JetBrains Mono", monospace; font-size: 24px; color: var(--fg-mute); letter-spacing: 0.16em; text-transform: uppercase; }
  .kb-stage.now .stage-name { color: var(--cyan); }
  .kb-stage h3 { font-size: 46px; font-weight: 700; margin: 0; color: var(--fg); line-height: 1.1; letter-spacing: -0.01em; }
  .kb-stage .desc { font-size: 28px; color: var(--fg-dim); line-height: 1.5; font-weight: 300; }
  .kb-stage .desc strong { color: var(--fg); font-weight: 500; }
  .kb-meta-table { margin-top: 16px; padding: 22px 24px; border-radius: 8px; background: #050B16; border: 1px solid var(--line); font-family: "JetBrains Mono", monospace; font-size: 22px; color: var(--fg-dim); line-height: 1.6; }
  .kb-meta-table.first { margin-top: auto; }
  .kb-stage > .kb-meta-table:nth-of-type(1) { margin-top: auto; }
  .kb-meta-table .row { display: grid; grid-template-columns: 110px 1fr; gap: 14px; align-items: baseline; padding: 4px 0; }
  .kb-meta-table .k { color: var(--cyan); font-size: 22px; }
  .kb-meta-table .t { color: var(--fg); font-size: 22px; }
  .kb-meta-table .sub { color: var(--fg-mute); font-size: 22px; padding-left: 14px; }
  .kb-meta-table.pros .pro { display: flex; gap: 10px; align-items: baseline; padding: 4px 0; font-size: 22px; }
  .kb-meta-table.pros .pro .ic { color: var(--green); }
  .kb-meta-table.pros .pro .tx { color: var(--fg); }

  /* ---- slide 20: 30 collectors + telegram ---- */
  .s-collectors .frame { padding: 120px 90px 140px; }
  .coll2-grid { flex: 1; display: grid; grid-template-columns: 1.25fr 1fr; gap: 50px; margin-top: 40px; align-items: stretch; min-height: 0; }
  .coll2-left { display: flex; flex-direction: column; gap: 28px; min-height: 0; }
  .coll2-label { font-family: "JetBrains Mono", monospace; font-size: 26px; color: var(--cyan); letter-spacing: 0.16em; }
  .coll2-cats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .coll2-cat { padding: 20px 22px; border: 1px solid var(--line); border-radius: 8px; background: rgba(255,255,255,0.025); display: flex; flex-direction: column; gap: 10px; }
  .coll2-cat .cd { width: 14px; height: 14px; border-radius: 50%; }
  .coll2-cat .cn { font-size: 32px; font-weight: 700; color: var(--fg); letter-spacing: 0.02em; line-height: 1.05; }
  .coll2-cat .ci { font-family: "JetBrains Mono", monospace; font-size: 18px; color: var(--fg-dim); line-height: 1.45; letter-spacing: 0.02em; }
  .coll2-feats { display: flex; flex-direction: column; gap: 14px; padding: 22px 28px; border: 1px solid var(--line-strong); border-radius: 10px; background: rgba(245,165,36,0.06); border-left: 3px solid var(--amber); margin-top: auto; }
  .coll2-feats .cf { display: grid; grid-template-columns: 40px 1fr; gap: 14px; align-items: baseline; }
  .coll2-feats .cf-i { font-size: 26px; }
  .coll2-feats .cf-t { font-size: 22px; color: var(--fg); line-height: 1.4; font-weight: 300; }
  .coll2-feats .cf-t strong { color: var(--amber); font-weight: 700; }
  .coll2-right { display: flex; flex-direction: column; gap: 16px; }
  .coll2-tg-cap { font-family: "JetBrains Mono", monospace; font-size: 20px; color: var(--cyan); letter-spacing: 0.14em; }
  .coll2-tg-img { flex: 1; min-height: 0; border: 1px solid var(--line-strong); border-radius: 12px; overflow: hidden; background: #0F1115; display: flex; align-items: center; justify-content: center; padding: 12px; }
  .coll2-tg-img img { max-width: 100%; max-height: 100%; object-fit: contain; border-radius: 6px; }
  .coll2-feats .cf { display: grid; grid-template-columns: 36px 1fr; gap: 14px; align-items: baseline; }
  .coll2-feats .cf-i { font-size: 24px; }
  .coll2-feats .cf-t { font-size: 24px; color: var(--fg-dim); line-height: 1.45; font-weight: 300; }
  .coll2-feats .cf-t strong { color: var(--amber); font-weight: 600; }
  .coll2-right { display: flex; flex-direction: column; padding: 0; border: 1px solid var(--line-strong); border-radius: 16px; background: #0f1620; overflow: hidden; }

/* ---- slide 24: Scale Curse (s-scale) ---- */
  .s-scale .frame { padding: 120px 90px 90px; align-items: center; text-align: center; }
  .s-scale .eyebrow { text-align: center; }
  .s-scale .title { text-align: center; font-size: 76px !important; }
  .s-scale .subtitle { text-align: center; font-size: 30px !important; margin-top: 6px; }
  .scale-mega { margin-top: 40px; font-family: "JetBrains Mono", monospace; font-size: 320px; font-weight: 700; line-height: 1; letter-spacing: -0.04em; color: var(--amber); text-shadow: 0 0 80px rgba(245,165,36,0.4); }
  .scale-stack-add { margin-top: 30px; display: flex; flex-direction: column; gap: 14px; align-items: center; font-family: "JetBrains Mono", monospace; font-size: 26px; color: var(--fg-dim); letter-spacing: 0.06em; }
  .scale-stack-add .row { display: flex; align-items: center; gap: 14px; }
  .scale-stack-add .plus { color: var(--amber); font-weight: 700; }
  .scale-stack-add .eq { font-size: 28px; color: var(--fg); font-weight: 600; padding: 14px 28px; border: 1px solid var(--amber); border-radius: 6px; background: rgba(245,165,36,0.05); margin-top: 12px; letter-spacing: 0.04em; }

/* ---- slide 25: Agent Inventory (s-agent2) ---- */
  .s-agent2 .frame { padding: 120px 90px 95px; }
  .ag2-flow { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; gap: 24px; align-items: stretch; margin-top: 48px; }
  .ag2-node { padding: 32px 28px; border: 1px solid var(--line); border-radius: 10px; background: rgba(255,255,255,0.02); display: flex; flex-direction: column; gap: 12px; }
  .ag2-node.src { border-color: rgba(91,224,232,0.4); }
  .ag2-node.act { border-color: rgba(245,165,36,0.5); background: rgba(245,165,36,0.04); }
  .ag2-node.out { border-color: rgba(217,70,239,0.4); }
  .ag2-node .hd { font-family: "JetBrains Mono", monospace; font-size: 18px; color: var(--fg-dim); letter-spacing: 0.12em; }
  .ag2-node .big { font-size: 36px; font-weight: 700; color: var(--fg); line-height: 1.25; }
  .ag2-node .sm { font-size: 20px; color: var(--fg-dim); }
  .ag2-arrow { font-family: "JetBrains Mono", monospace; font-size: 56px; color: var(--fg-dim); align-self: center; }
  .ag2-three { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 40px; }
  .ag2-card { padding: 28px 26px; border: 1px solid var(--line); border-radius: 10px; background: rgba(255,255,255,0.025); display: flex; flex-direction: column; gap: 10px; }
  .ag2-card .ic { font-size: 28px; color: var(--amber); font-weight: 700; }
  .ag2-card h3 { font-size: 36px; font-weight: 700; margin: 0; }
  .ag2-card p { font-size: 22px; line-height: 1.55; color: var(--fg-dim); margin: 0; }
  .ag2-card p strong { color: var(--cyan); }
  .ag2-foot { margin-top: 36px; padding: 22px 28px; border: 1px solid var(--line); border-radius: 8px; background: rgba(91,224,232,0.04); display: flex; gap: 22px; align-items: baseline; }
  .ag2-foot .lbl { font-family: "JetBrains Mono", monospace; font-size: 16px; color: var(--cyan); letter-spacing: 0.1em; flex-shrink: 0; }
  .ag2-foot .text { font-size: 26px; color: var(--fg); }
  .ag2-foot .text strong { color: var(--amber); font-weight: 700; }

  /* ---- new P27: Fire (big-text redesign) ---- */
  .s-fire2 .frame { padding: 110px 80px 95px; gap: 0; }
  .s-fire2 .eyebrow { font-size: 22px !important; }
  .s-fire2 .title { font-size: 64px !important; line-height: 1.1; margin-top: 4px; }
  .fire2-quote { margin-top: 12px; padding: 14px 24px; border-left: 5px solid var(--amber); background: rgba(245,165,36,0.07); font-size: 36px; font-weight: 700; color: var(--fg); letter-spacing: 0.02em; }
  .fire2-stack { display: flex; flex-direction: column; gap: 14px; margin-top: 14px; flex: 1; min-height: 0; }
  .fire2-pool { padding: 14px 22px; border: 1px solid var(--line); border-radius: 10px; background: rgba(255,255,255,0.025); }
  .fire2-pool .lbl, .fire2-stages .lbl { font-family: "JetBrains Mono", monospace; font-size: 20px; color: var(--fg-dim); letter-spacing: 0.12em; }
  .fire2-pool .pool-row { display: flex; align-items: center; gap: 14px; margin-top: 10px; }
  .fire2-pool .step { flex: 1; padding: 12px 18px; border: 1px solid var(--line); border-radius: 8px; text-align: center; }
  .fire2-pool .step .n { font-family: "JetBrains Mono", monospace; font-size: 52px; font-weight: 700; color: var(--amber); line-height: 1; }
  .fire2-pool .step .d { margin-top: 6px; font-size: 26px; color: var(--fg-dim); }
  .fire2-pool .arrow { font-family: "JetBrains Mono", monospace; font-size: 40px; color: var(--fg-dim); }
  .fire2-pool .src { margin-top: 10px; font-family: "JetBrains Mono", monospace; font-size: 20px; color: var(--cyan); letter-spacing: 0.1em; text-align: right; }
  .fire2-stages { padding: 14px 22px; border: 1px solid var(--line); border-radius: 10px; background: rgba(255,255,255,0.025); }
  .fire2-stages .six { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; margin-top: 8px; }
  .fire2-stages .stg { padding: 10px 8px; border: 1px solid var(--line); border-radius: 8px; text-align: center; background: rgba(245,165,36,0.04); }
  .fire2-stages .stg .t { font-family: "JetBrains Mono", monospace; font-size: 20px; color: var(--amber); font-weight: 700; }
  .fire2-stages .stg .n { margin-top: 2px; font-size: 28px; font-weight: 700; color: var(--fg); }
  .fire2-stages .cov { margin-top: 10px; font-size: 22px; color: var(--fg-dim); text-align: right; }
  .fire2-bottom { display: grid; grid-template-columns: 1fr 1fr 1.1fr; gap: 14px; }
  .fire2-bottom .col { padding: 12px 18px; border: 1px solid var(--line); border-radius: 10px; background: rgba(255,255,255,0.025); display: flex; flex-direction: column; gap: 4px; }
  .fire2-bottom .col .lbl { font-family: "JetBrains Mono", monospace; font-size: 18px; color: var(--fg-dim); letter-spacing: 0.12em; }
  .fire2-bottom .col .hit { font-size: 24px; color: var(--fg); }
  .fire2-bottom .col .hit strong { color: var(--amber); font-weight: 700; }
  .fire2-bottom .col.gaps { background: rgba(255,138,76,0.06); border-color: rgba(255,138,76,0.4); }
  .fire2-bottom .col.gaps .hit { color: #FFB4B4; }
  .fire2-bottom .col.stamp { background: rgba(91,224,232,0.05); border-color: rgba(91,224,232,0.4); justify-content: center; align-items: center; text-align: center; }
  .fire2-bottom .col.stamp .big { font-size: 32px; font-weight: 700; color: var(--cyan); letter-spacing: 0.04em; line-height: 1.15; }
  .fire2-bottom .col.stamp .sub { margin-top: 6px; font-family: "JetBrains Mono", monospace; font-size: 20px; color: var(--fg); letter-spacing: 0.16em; }

  /* ---- new P28/P29: Big screenshot pair ---- */
  .s-shots2 .frame { padding: 110px 80px 95px; gap: 0; }
  .s-shots2 .eyebrow { font-size: 22px !important; }
  .s-shots2 .title { font-size: 52px !important; margin-top: 4px; line-height: 1.15; }
  .shots2-row { flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 22px; min-height: 0; }
  .shots2-row figure { margin: 0; display: flex; flex-direction: column; gap: 12px; min-height: 0; }
  .shots2-row figure figcaption { font-family: "JetBrains Mono", monospace; font-size: 22px; color: var(--cyan); letter-spacing: 0.04em; flex-shrink: 0; }
  .shots2-row figure img { flex: 1; min-height: 0; width: 100%; height: 100%; object-fit: contain; object-position: top; border: 1px solid var(--line); border-radius: 10px; background: #0a1018; }

/* ---- slide 32: Water Layers (s-matrix) ---- */
  .s-matrix .frame { padding: 120px 90px 95px; }
  .matrix-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 60px; }
  .matrix-head .left h2 { font-size: 72px; margin: 0; line-height: 1.05; }
  .matrix-head .left .eyebrow-hd { font-family: "JetBrains Mono", monospace; font-size: 22px; color: var(--cyan); letter-spacing: 0.2em; margin-bottom: 16px; }
  .matrix-head .left .sub { font-size: 28px; color: var(--fg-dim); margin-top: 16px; font-weight: 300; line-height: 1.45; max-width: 1240px; }
  .matrix-head .right { font-family: "JetBrains Mono", monospace; font-size: 24px; color: var(--fg-mute); letter-spacing: 0.14em; text-align: right; line-height: 1.7; }

  .water-stage { margin-top: 28px; display: grid; grid-template-columns: 1fr 50px 1fr; gap: 0; flex: 1; min-height: 0; align-items: stretch; }

  /* layers */
  .layers-col { position: relative; display: flex; flex-direction: column; gap: 12px; padding-right: 18px; min-height: 0; }
  .layer { position: relative; display: grid; grid-template-columns: 70px 1fr; gap: 16px; align-items: center; padding: 14px 18px; border: 1px solid var(--line); background: rgba(255,255,255,0.02); border-radius: 10px; flex: 1; min-height: 0; }
  .layer-glyph { width: 70px; height: 56px; display: flex; align-items: center; justify-content: center; }
  .layer-glyph svg { width: 100%; height: 100%; }
  .layer-body { display: flex; flex-direction: column; gap: 6px; }
  .layer-label { display: flex; align-items: baseline; gap: 14px; }
  .layer-label .ch { font-size: 36px; font-weight: 700; color: var(--fg); letter-spacing: 0.04em; }
  .layer-label .en { font-family: "JetBrains Mono", monospace; font-size: 20px; color: var(--fg-mute); letter-spacing: 0.18em; }
  .static-tag { color: var(--fg-mute); font-family: "JetBrains Mono", monospace; font-size: 17px; letter-spacing: 0.16em; padding: 3px 9px; border: 1px solid var(--line); border-radius: 3px; align-self: center; }
  .dyn-tag { color: var(--cyan); font-family: "JetBrains Mono", monospace; font-size: 17px; letter-spacing: 0.16em; padding: 3px 9px; border: 1px solid rgba(91,224,232,0.4); border-radius: 3px; background: rgba(91,224,232,0.06); align-self: center; }

  .layer-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; font-size: 25px; color: var(--fg-dim); font-weight: 300; }
  .layer-row + .layer-row { margin-top: 4px; }
  .layer-row .item { font-size: 25px; }
  .layer-row .item.dyn { color: var(--cyan); }

  /* connector */
  .connector { position: relative; }
  .connector svg { width: 100%; height: 100%; display: block; }

  /* narrative */
  .narrative-col { display: flex; flex-direction: column; padding-left: 18px; min-height: 0; }
  .narrative-head { font-family: "JetBrains Mono", monospace; font-size: 22px; color: var(--cyan); letter-spacing: 0.22em; margin-bottom: 18px; }
  .narrative-flow { display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .narr-step { display: grid; grid-template-columns: 48px 1fr; gap: 14px; align-items: center; padding: 12px 16px; border: 1px solid var(--line); border-radius: 10px; background: rgba(255,255,255,0.02); flex: 1; min-height: 0; }
  .narr-step .num { font-family: "JetBrains Mono", monospace; font-size: 26px; color: var(--cyan); font-weight: 600; }
  .narr-step .body { display: flex; flex-direction: column; gap: 6px; }
  .narr-step .body .q { font-size: 30px; color: var(--fg); font-weight: 600; }
  .narr-step .body .src { font-size: 22px; color: var(--fg-mute); font-weight: 300; }
  .narr-step .body .src .pill { display: inline-block; padding: 2px 10px; border: 1px solid var(--line); border-radius: 3px; margin-right: 6px; font-family: "JetBrains Mono", monospace; font-size: 17px; letter-spacing: 0.14em; color: var(--fg-dim); }
  .narrative-foot { margin-top: 12px; padding: 12px 18px 0; border-top: 1px solid var(--line); font-size: 22px; color: var(--fg-dim); font-weight: 300; line-height: 1.45; }
  .narrative-foot strong { color: var(--fg); font-weight: 600; }

  /* ---- NEW slide 31: Fire case ---- */
  .s-firecase .frame { padding: 120px 90px 95px; }
  .s-firecase .fcase-head { display: flex; align-items: baseline; justify-content: space-between; gap: 32px; flex-wrap: wrap; }
  .s-firecase .fcase-head h2 { font-size: 60px; font-weight: 700; margin: 0; line-height: 1.1; letter-spacing: -0.015em; }
  .s-firecase .fcase-head h2 .acc { color: var(--amber); }
  .s-firecase .fcase-meta { font-family: "JetBrains Mono", monospace; font-size: 20px; color: var(--fg-mute); letter-spacing: 0.06em; line-height: 1.5; }
  .s-firecase .fcase-meta .dot { color: var(--cyan); margin: 0 8px; }
  .s-firecase .fcase-row { flex: 1; display: grid; grid-template-columns: 1.05fr 1fr; gap: 24px; margin-top: 22px; min-height: 0; }
  .s-firecase figure { margin: 0; display: flex; flex-direction: column; gap: 10px; min-height: 0; }
  .s-firecase figure figcaption { font-family: "JetBrains Mono", monospace; font-size: 18px; color: var(--cyan); letter-spacing: 0.05em; flex-shrink: 0; }
  .s-firecase figure img { flex: 1; min-height: 0; width: 100%; height: 100%; object-fit: contain; object-position: top; border: 1px solid var(--line); border-radius: 10px; background: #0a1018; }
  .s-firecase .fcase-bot { margin-top: 18px; padding: 18px 24px; border: 1px solid rgba(245,165,36,0.35); border-radius: 10px; background: rgba(245,165,36,0.05); display: flex; gap: 24px; align-items: center; }
  .s-firecase .fcase-bot .lab { font-family: "JetBrains Mono", monospace; font-size: 16px; color: var(--amber); letter-spacing: 0.16em; flex: 0 0 auto; }
  .s-firecase .fcase-bot .txt { font-size: 22px; color: var(--fg); font-weight: 300; line-height: 1.45; }
  .s-firecase .fcase-bot .txt strong { color: var(--amber); font-weight: 600; }

  /* ---- Weekly brief full-bleed ---- */
  .s-weekly { background: #000; }
  .s-weekly .frame { display: none; }
  .weekly-bg { position: absolute; inset: 0; background-image: url("assets/weekly-brief.png"); background-size: contain; background-repeat: no-repeat; background-position: center; background-color: #0a0d18; }
  .weekly-overlay { position: absolute; top: 32px; left: 50%; transform: translateX(-50%); display: flex; align-items: center; gap: 18px; padding: 12px 22px; background: rgba(15,21,37,0.85); border: 1px solid var(--amber); border-radius: 8px; backdrop-filter: blur(8px); z-index: 5; }
  .weekly-overlay .weekly-badge { font-family: "JetBrains Mono", monospace; font-size: 16px; color: var(--amber); letter-spacing: 0.18em; padding: 4px 10px; border: 1px solid var(--amber); border-radius: 4px; }
  .weekly-overlay > span:last-child { font-size: 18px; color: var(--fg); font-weight: 600; }

</style>
</head>
<body>
<deck-stage width="1920" height="1080">

  <!-- ════════════ OPENING 開場 ════════════ -->

  <!-- ============ P1 標題頁 ============ -->
  <section class="slide full s-title" data-label="P01 標題頁" data-screen-label="P01 Title">
    <div class="bg" style="background-image:url('assets/p13_oblique.png');"></div>
    <div class="title-scrim"></div>
    <div class="title-center">
      <div class="eb anim">2026.06.12</div>
      <h1 class="anim d1">從一架飛機的軌跡開始</h1>
      <p class="sub anim d2">一個資料分析師，用 AI 把台灣的開放資料變成會呼吸的地圖</p>
    </div>
    <div class="title-meta anim d3">
      <div class="claim">當 AI 已能自己寫 ETL，資料人不是消失 —— 是升級為<strong>系統設計者</strong></div>
      <div class="spk">MIGU<span class="d">｜</span>資料分析師</div>
    </div>
    <div class="cornermono" style="bottom:60px;left:var(--pad-x);right:auto;">FR24 · 41,766 TRACKS · THREE.JS GLSL</div>
  </section>

  <!-- ============ P2 自我介紹 ============ -->
  <section class="slide s-intro" data-label="P02 自我介紹" data-screen-label="P02">
    <div class="chrome-top"><span class="mark"><i class="dot"></i>OPENING · 開場</span><span class="pg">P2 / 81</span></div>
    <div class="frame">
      <div class="avatar-wrap anim">
        <img class="avatar" src="assets/p02.jpg" alt="migu 頭像 · 黑貓" />
        <div class="avatar-ring"></div>
      </div>
      <div class="intro-right">
        <h1 class="anim">Hi, 我是 migu</h1>
        <div class="bio anim d1">資料分析師 · <strong>待過三間公司的數據團隊</strong></div>
        <ul class="intro-pts anim d2">
          <li>大學碰過 GIS（都計背景），出社會走資料分析，很久沒再碰</li>
          <li>金融、新創都待過</li>
          <li>AI 的努力嘗試者</li>
        </ul>
        <div class="intro-mono anim d3">DATA ANALYST · 3 TEAMS · GIS SIDE PROJECT</div>
      </div>
    </div>
  </section>

  <!-- ============ P3 路線圖 ============ -->
  <section class="slide s-con" data-label="P03 今天的四段路" data-screen-label="P03">
    <div class="chrome-top"><span class="mark"><i class="dot"></i>OPENING · 路線圖</span><span class="pg">P3 / 81</span></div>
    <div class="frame">
      <div class="con-head anim">
        <h2>今天的四段路</h2>
        <p class="sub">成果介紹 → 心法 → 專案示範 → 展望</p>
      </div>
      <div class="road anim d1">
        <div class="cell hot">
          <span class="wt">本場最重</span>
          <div class="no">01</div><div class="glyph">◐</div>
          <div class="en">SHOWCASE</div><div class="zh">成果介紹</div>
          <div class="pp">P4–27 · 60 MIN</div>
        </div>
        <div class="cell">
          <div class="no">02</div><div class="glyph">⟳</div>
          <div class="en">AI CODING</div><div class="zh">心法</div>
          <div class="pp">P28–36 · 22 MIN</div>
        </div>
        <div class="cell">
          <div class="no">03</div><div class="glyph">▤</div>
          <div class="en">BUILD</div><div class="zh">專案示範</div>
          <div class="pp">P37–51 · 35 MIN</div>
        </div>
        <div class="cell">
          <div class="no">04</div><div class="glyph">◇</div>
          <div class="en">HORIZON</div><div class="zh">展望</div>
          <div class="pp">P52–57 · 15 MIN</div>
        </div>
      </div>
      <div class="undercurrent anim d2">
        <span class="end">本業＝<strong>半放權</strong>（有掌握度，不放心放手）</span>
        <span class="ln"></span>
        <span class="end">GIS＝<strong>完全放權</strong>（什麼都不會，練得最徹底）</span>
      </div>
    </div>
  </section>

  <!-- ============ SECTION COVER ============ -->
  <section class="slide s-cover" data-label="01 SHOWCASE 成果介紹" data-screen-label="SHOWCASE Cover">
    <div class="num-mega mono">01</div>
    <div class="frame">
      <div>
        <div class="eyebrow">SHOWCASE · 成果介紹</div>
        <h2 class="title anim">成果介紹</h2>
        <p class="lead anim d1">從一個個的 CSV，到一張會呼吸的台灣地圖。陸、海、空全部疊起來。</p>
      </div>
      <div class="toc">
        <span class="now">01 SHOWCASE</span><span>02 AI CODING</span><span>03 BUILD</span><span>04 HORIZON</span>
      </div>
    </div>
  </section>

  <!-- ============ P4 一切的起點 ============ -->
  <section class="slide full" data-label="P04 一切的起點" data-screen-label="P04">
    <div class="bg" style="background-image:url('assets/p04.png')"></div>
    <div class="scrim left"></div>
    <div class="chrome-top"><span class="mark"><i class="dot"></i>SHOWCASE · 成果介紹</span><span class="pg">P4 / 81</span></div>
    <div class="full-body" style="max-width:1180px;">
      <div class="stamp cy anim" style="margin-bottom:30px;"><span class="k">DAY 0</span> 第一張地圖</div>
      <div class="case-label anim">起點 · KEPLER.GL</div>
      <h2 class="anim d1">一切的起點</h2>
      <p class="sub anim d2">把一份 CSV 轉成 GeoJSON 拖進 Kepler.gl，就有了第一張地圖 ——「原來台灣有這麼多資料，<strong>原來轉成地圖並不難</strong>」。</p>
    </div>
    <div class="cornermono">KEPLER.GL · CSV → GeoJSON · 0 行程式</div>
  </section>

  <!-- ============ P5 Case 1 Mini Taipei ============ -->
  <section class="slide full" data-label="P05 Case 1 Mini Taipei" data-screen-label="P05">
    <div class="bg" style="background-image:url('assets/p05.png')"></div>
    <div class="scrim bottom"></div>
    <div class="chrome-top"><span class="mark"><i class="dot"></i>SHOWCASE · 成果介紹</span><span class="pg">P5 / 81</span></div>
    <div class="demo-pill anim" style="position:absolute;left:var(--pad-x);top:140px;z-index:4;"><span class="tri"></span>LIVE DEMO</div>
    <div class="full-body">
      <div class="bottom-row">
        <div>
          <div class="case-label anim">CASE 1</div>
          <h2 class="anim d1">Mini Taipei</h2>
          <p class="sub anim d2">捷運 → 台鐵 → 高鐵，三套軌道疊成一張會動的地圖。<strong>體驗到動態的魅力。</strong></p>
        </div>
        <ul class="meta-list anim d2">
          <li><strong>TDX</strong> 開放資料</li>
          <li>6 SYSTEMS</li>
          <li>351 TRAINS LIVE</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ P6 Case 2 衛星 ============ -->
  <section class="slide full" data-label="P06 Case 2 衛星" data-screen-label="P06">
    <div class="bg" style="background-image:url('assets/p06_satellite.png')"></div>
    <div class="scrim bottom"></div>
    <div class="chrome-top"><span class="mark"><i class="dot"></i>SHOWCASE · 成果介紹</span><span class="pg">P6 / 81</span></div>
    <div class="bridge-card anim" style="position:absolute;right:var(--pad-x);top:150px;width:430px;aspect-ratio:1/1;z-index:4;border-radius:12px;">
      <div class="ci" style="background-image:url('assets/p06_solar.png')"></div>
      <div class="cap" style="left:22px;bottom:18px;"><div class="m">SOLAR SYSTEM</div></div>
    </div>
    <div class="full-body" style="max-width:1180px;">
      <div class="case-label anim">CASE 2</div>
      <h2 class="anim d1">衛星</h2>
      <p class="sub anim d2">用公開 TLE 推算衛星軌道，再延伸到太陽系 —— <strong>同一套做法，只要有資料，都可以無限延伸。</strong></p>
    </div>
    <div class="cornermono">CELESTRAK TLE · SGP4</div>
  </section>

  <!-- ============ P7 Case 3 船舶 ============ -->
  <section class="slide full" data-label="P07 Case 3 船舶" data-screen-label="P07">
    <div class="bg" style="background-image:url('assets/p07.png')"></div>
    <div class="scrim bottom"></div>
    <div class="chrome-top"><span class="mark"><i class="dot"></i>SHOWCASE · 成果介紹</span><span class="pg">P7 / 81</span></div>
    <div class="full-body">
      <div class="bottom-row">
        <div style="max-width:1180px;">
          <div class="case-label anim">CASE 3</div>
          <h2 class="anim d1">船舶</h2>
          <p class="sub anim d2">航港局 AIS 即時點位 —— 青藍光球 + 30 分鐘漸層拖尾，畫出台灣周邊海域的脈動。</p>
        </div>
        <ul class="meta-list anim d2">
          <li><strong>AIS</strong> 即時點位</li>
          <li>~10 MIN 更新</li>
          <li>台灣周邊海域</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ P8 Case 4 Pulse ============ -->
  <section class="slide full" data-label="P08 Case 4 Pulse" data-screen-label="P08">
    <div class="bg" style="background-image:url('assets/p08.png')"></div>
    <div class="scrim bottom"></div>
    <div class="chrome-top"><span class="mark"><i class="dot"></i>SHOWCASE · 成果介紹</span><span class="pg">P8 / 81</span></div>
    <div class="demo-pill anim" style="position:absolute;left:var(--pad-x);top:140px;z-index:4;"><span class="tri"></span>LIVE DEMO</div>
    <div class="full-body">
      <div class="case-label anim">CASE 4 · MINI TAIWAN PULSE</div>
      <h2 class="anim d1">台灣的脈動</h2>
      <p class="sub anim d2" style="margin-bottom:34px;">天空、海洋、大地、街道、清運 —— <strong>五脈共動</strong>，疊成同一張會呼吸的地圖。第一次從「靜態 JSON」進化成「時空間資料庫」。</p>
      <div class="numrow anim d2">
        <div class="stat"><div class="n">5<span class="u">脈共動</span></div><div class="l">飛機 / 船 / 列車 / 公車 / 垃圾車</div></div>
        <div class="stat"><div class="n">23<span class="u">圖層</span></div><div class="l">十大分類 · 獨立 toggle</div></div>
        <div class="stat"><div class="n">5,700<span class="u">+ 輛公車</span></div><div class="l">TDX · 30s polling</div></div>
      </div>
    </div>
  </section>

  <!-- ============ P9 整合案例 農×水 ============ -->
  <section class="slide full" data-label="P09 整合 農×水" data-screen-label="P09">
    <div class="bg" style="background-image:url('assets/p09.png')"></div>
    <div class="scrim bottom"></div>
    <div class="chrome-top"><span class="mark"><i class="dot"></i>SHOWCASE · 整合案例</span><span class="pg">P9 / 81</span></div>
    <div class="legend anim" style="right:var(--pad-x);top:150px;">
      <div class="it"><span class="sw" style="background:#22D38C;"></span>農田範圍</div>
      <div class="it"><span class="sw" style="background:#5BE0E8;"></span>灌排溝渠 · 水系</div>
      <div class="it"><span class="sw" style="background:#F5A524;"></span>河川幹線</div>
    </div>
    <div class="full-body">
      <div class="bottom-row">
        <div style="max-width:1150px;">
          <div class="case-label anim">整合案例 · 農 × 水</div>
          <h2 class="anim d1">三個部會的孤島，疊成一張圖</h2>
          <p class="sub anim d2">農田、河川、溝渠、堤防、淹水潛勢同框 —— 這不是地圖漂亮，是<strong>把孤島 JOIN 起來</strong>。</p>
        </div>
        <div class="anim d2" style="text-align:right;flex:0 0 auto;">
          <div class="mono" style="font-size:64px;font-weight:700;color:#fff;line-height:1;">400MB <span style="color:var(--cyan);">→</span> ~5MB</div>
          <div class="mono" style="font-size:24px;color:var(--fg-mute);letter-spacing:0.12em;margin-top:14px;">PMTILES · HTTP RANGE REQUEST</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ P10 整合案例 醫療 ============ -->
  <section class="slide full" data-label="P10 整合 醫療資源" data-screen-label="P10">
    <div class="bg" style="background-image:url('assets/p10.png')"></div>
    <div class="scrim bottom"></div>
    <div class="chrome-top"><span class="mark"><i class="dot"></i>SHOWCASE · 整合案例</span><span class="pg">P10 / 81</span></div>
    <div class="full-body">
      <div class="bottom-row">
        <div style="max-width:1180px;">
          <div class="case-label anim">整合案例 · 醫療資源</div>
          <h2 class="anim d1">把民生疊在人口上，缺口自己浮出來</h2>
          <p class="sub anim d2">醫院、診所、藥局、AED、長照點位 + 等時圈 —— 看見可及性，也看見<strong>醫療沙漠</strong>。</p>
        </div>
        <ul class="meta-list anim d2">
          <li><strong>NHI + 衛福部</strong></li>
          <li>POI × 人口 × 等時圈</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ P11 整合案例 大雨 ============ -->
  <section class="slide full" data-label="P11 整合 大雨與災害" data-screen-label="P11">
    <div class="bg" style="background-image:url('assets/p11.png')"></div>
    <div class="scrim bottom"></div>
    <div class="chrome-top"><span class="mark"><i class="dot"></i>SHOWCASE · 整合案例</span><span class="pg">P11 / 81</span></div>
    <div class="full-body">
      <div class="bottom-row">
        <div style="max-width:1180px;">
          <div class="case-label anim">整合案例 · 大雨與災害</div>
          <h2 class="anim d1">一條 Timeline，全部聯動</h2>
          <p class="sub anim d2">雷達回波、水庫、雨量、災害示警 —— 不同頻率在 RPC 層統一，<strong>一拖時間軸全部同步回放</strong>。</p>
        </div>
        <ul class="meta-list anim d2">
          <li><strong>CWA</strong> 雷達</li>
          <li>雨量 10MIN</li>
          <li>水庫日更 → 1 TIMELINE</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ P12 會動的台灣 · LIVE DEMO ============ -->
  <section class="slide s-livedemo" data-label="P12 會動的台灣 LIVE" data-screen-label="P12 Live Demo">
    <div class="ld-bg">
      <div style="background-image:url('assets/p08.png');"></div>
      <div style="background-image:url('assets/p07.png');"></div>
      <div style="background-image:url('assets/p05.png');"></div>
    </div>
    <div class="ld-scrim"></div>
    <div class="chrome-top"><span class="mark"><i class="dot"></i>SHOWCASE · 動態展示</span><span class="pg">P12 / 81</span></div>
    <div class="ld-center">
      <div class="ld-pill anim"><span class="tri"></span>LIVE DEMO · 切換實機</div>
      <h2 class="ld-title anim d1">會動的台灣</h2>
      <p class="ld-sub anim d2">切換到電腦，實際展示 —— 船、公車、列車同時在地圖上跑。<br>接著，把鏡頭拉到天上 ✈</p>
    </div>
  </section>

  <!-- ============ P13 Plan R 航班軌跡 ============ -->
  <section class="slide full" data-label="P13 Plan R 航班軌跡" data-screen-label="P13">
    <div class="bg" style="background-image:url('assets/p13_top.png')"></div>
    <div class="scrim bottom"></div>
    <div class="chrome-top"><span class="mark"><i class="dot"></i>SHOWCASE · PLAN R</span><span class="pg">P13 / 81</span></div>
    <div class="demo-pill anim" style="position:absolute;left:var(--pad-x);top:140px;z-index:4;"><span class="tri"></span>LIVE DEMO</div>
    <div class="full-body">
      <div class="case-label anim">PLAN R · 航班軌跡</div>
      <h2 class="anim d1">飛機的軌跡，可以是一件藝術品</h2>
      <p class="sub anim d2" style="margin-bottom:38px;">在北美館看展時冒出的念頭。資料本來是冰冷的 JSON，用對渲染手法，<strong>它就是藝術。</strong></p>
      <div class="numrow anim d2">
        <div class="stat"><div class="n">41,766</div><div class="l">TRACKS 軌跡</div></div>
        <div class="stat"><div class="n">1,356</div><div class="l">AIRPORTS 機場</div></div>
        <div class="stat"><div class="n">48<span class="u">天</span></div><div class="l">樣本期</div></div>
      </div>
    </div>
    <div class="cornermono">REACT 19 · MAPBOX · THREE.JS · GLSL</div>
  </section>

  <!-- ============ P14 模式① 軌跡視覺化 ============ -->
  <section class="slide full" data-label="P14 模式① 軌跡視覺化" data-screen-label="P14">
    <div class="bg" style="background-image:url('assets/p14.png')"></div>
    <div class="scrim bottom"></div>
    <div class="chrome-top"><span class="mark"><i class="dot"></i>SHOWCASE · PLAN R</span><span class="pg">P14 / 81</span></div>
    <div class="callout anim" style="left:55%;top:13%;align-items:flex-start;">
      <div class="lbl">東京灣迴旋進場 ↘</div>
      <div class="ln" style="width:160px;"></div>
    </div>
    <div class="full-body">
      <div class="bottom-row">
        <div style="max-width:1180px;">
          <div class="case-label anim">模式 ① · 軌跡視覺化</div>
          <h2 class="anim d1">把一段時間的所有起降，畫成一張航跡圖</h2>
          <p class="sub anim d2">高度色變 + 光軌拖尾，一眼看出進場 / 離場的結構。疊起來，就是一張機場的<strong>「指紋」</strong>。</p>
        </div>
        <ul class="meta-list anim d2">
          <li><strong>RJTT</strong> 羽田</li>
          <li>1,318 TRACKS</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ P14a 軌跡畫廊 ============ -->
  <section class="slide s-gallery" data-label="P14a 軌跡畫廊" data-screen-label="P14a">
    <div class="gal">
      <div class="cell"><div class="ci" style="background-image:url('assets/p14a_hk.png')"></div><div class="icao"><div class="code">VHHH</div><div class="nm">香港</div></div></div>
      <div class="cell"><div class="ci" style="background-image:url('assets/p14a_fra.png')"></div><div class="icao"><div class="code">EDDF</div><div class="nm">法蘭克福</div></div></div>
